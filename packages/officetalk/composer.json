{
    "name": "officetalk/officetalk",
    "description": "Redaktionelles LinkedIn-Videointerview-Subsystem für immobilien-redaktion.com. Enthält Domain-Modelle, Blade-Komponenten, Routes und AI-Guidelines für Laravel Boost und Claude Code.",
    "type": "library",
    "license": "proprietary",
    "keywords": ["laravel", "immobilien", "officetalk", "videointerview", "boost", "claude"],
    "authors": [
        {
            "name": "Gerhard Popp",
            "email": "redaktion@immobilien-redaktion.com",
            "homepage": "https://immobilien-redaktion.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.5",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Officetalk\\": "src/",
            "Officetalk\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Officetalk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Officetalk\\OfficetalkServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
